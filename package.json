{
  "name": "@mdz/mirador-synchronized-voices",
  "version": "0.1.0",
  "description": "Plugin für die synchrone Darstellung mehrerer Stimmen eines Stimmbuchs",
  "keywords": [
    "iiif",
    "mirador",
    "mirador4",
    "mirador-plugin",
    "react-component"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitlab.lrz.de/mdz/webapps/libs/npm/mirador-synchronized-voices"
  },
  "license": "MIT",
  "author": "Christian Kaufhold",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:demo && npm run build:plugin",
    "prebuild:demo": "rimraf demo/dist",
    "build:demo": "tsc && BUILD_MODE=demo vite build",
    "prebuild:plugin": "rimraf dist",
    "build:plugin": "tsc && vite build",
    "format": "eslint . --ext js,jsx,ts,tsx --fix --max-warnings 0 --report-unused-disable-directives",
    "lint": "eslint . --ext js,jsx,ts,tsx --max-warnings 0 --report-unused-disable-directives",
    "prepublishOnly": "npm run build",
    "prepreview": "npm run build:demo",
    "preview": "BUILD_MODE=demo vite preview",
    "start": "vite"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.3",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "mirador": "^4.0.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "mirador": "4.x",
    "react": "19.x",
    "react-dom": "19.x"
  },
  "engines": {
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9"
  }
}
